FROM python:3.12-slim
ENV PYTHONUNBUFFERED=1 PYTHONDONTWRITEBYTECODE=1 PYTHONPATH=/app
WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY common/ ./common/
COPY data_pipeline/ ./data_pipeline/
COPY backend/ ./backend/

EXPOSE 8000
# Build the index (keyless stub embedder unless a key is in the env), then serve.
CMD ["sh", "-c", "python -m data_pipeline.run_ingest && uvicorn backend.app.main:app --host 0.0.0.0 --port 8000"]
