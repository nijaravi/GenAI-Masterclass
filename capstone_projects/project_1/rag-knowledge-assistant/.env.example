# Copy to `.env` and fill in. Never commit the real .env.

ENVIRONMENT=dev
LOG_LEVEL=INFO
LOG_JSON=false            # false = pretty logs in dev; true = JSON in prod

# --- LLM providers ---
OPENAI_API_KEY=sk-...
GROQ_API_KEY=             # optional; enables Llama-3.1-8b routing
FAST_MODEL=gpt-4o-mini
SMART_MODEL=gpt-4o
GROQ_MODEL=llama-3.1-8b-instant
PREFER_GROQ_FOR_FAST=false

# --- Embeddings ---
EMBEDDING_PROVIDER=openai            # openai | local
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536                   # 1536 for OpenAI small, 384 for MiniLM
# For fully offline mode:
# EMBEDDING_PROVIDER=local
# EMBEDDING_DIM=384

# --- Vector store ---
VECTOR_STORE=chroma                  # chroma | pgvector
CHROMA_PATH=./.chroma
PG_DSN=postgresql://rag:rag@localhost:5432/rag

# --- Retrieval tuning ---
DENSE_TOP_K=20
SPARSE_TOP_K=20
FUSED_TOP_K=12
RERANK_TOP_N=5
USE_RERANKER=true

# --- Cache ---
CACHE_ENABLED=true
CACHE_SIMILARITY_THRESHOLD=0.95
