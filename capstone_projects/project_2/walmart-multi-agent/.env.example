OPENAI_API_KEY=sk-your-openai-key-here

# ── PGVector connection ────────────────────────────────────────────────────────
# Local dev:  postgresql://postgres:postgres@localhost:5432/walmart_ai
# Docker:     postgresql://postgres:postgres@db:5432/walmart_ai
# Cloud (e.g. Supabase / Neon / RDS):
#             postgresql://user:password@host:5432/dbname
PGVECTOR_CONNECTION_STRING=postgresql://postgres:postgres@localhost:5432/walmart_ai

# ── Demo mode (no Postgres required — uses in-memory FAISS) ───────────────────
DEMO_MODE=true
