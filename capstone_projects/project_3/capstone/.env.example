# ── Demo mode ────────────────────────────────────────────────────────────
# true  -> no external services needed. Uses a deterministic rule-based
#          "model" for planning/routing text and an in-memory Chroma store
#          seeded with sample docs. Runs fully offline.
# false -> uses OPENAI_API_KEY for the LLM calls and PINECONE_API_KEY for
#          retrieval (falls back to Chroma if Pinecone vars are unset).
DEMO_MODE=true

# ── Model provider (only needed when DEMO_MODE=false) ───────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Vector store (only needed when DEMO_MODE=false and you want Pinecone) ─
PINECONE_API_KEY=
PINECONE_INDEX=orchestrator-platform

# ── Checkpointer (conversation persistence across turns) ────────────────
# Leave blank to use LangGraph's in-memory checkpointer (fine for a demo /
# single-process run). Set to a Postgres URL to use a durable checkpointer,
# matching the production pattern in the design doc (Section 11).
CHECKPOINTER_DB_URL=

# ── A2A external agent (Section 4.8 / 7.4) ───────────────────────────────
# URL of the external vendor agent this platform delegates to. The repo
# ships a local mock vendor agent (app/a2a/external_vendor_agent.py) that
# runs on this port by default.
EXTERNAL_AGENT_URL=http://localhost:9001
A2A_TIMEOUT_SECONDS=6
A2A_MAX_RETRIES=1
