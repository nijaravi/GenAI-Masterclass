# Template only — docker-compose does NOT read this file.
# Copy to app/.env and add your real key:
#   cp .env.example app/.env
OPENAI_API_KEY=sk-your-key-here

# Optional overrides (defaults shown)
# CHROMA_PATH=./chroma_data
# RAG_TOP_K=3
# RAG_MIN_RELEVANCE=0.65   # max cosine distance; 0.35 is too strict for most queries
# LOG_LEVEL=INFO
# LOG_FILE=logs/techstore_api.log   # appears at ./logs/ on your machine via docker-compose
